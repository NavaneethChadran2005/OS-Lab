alias currPID R0;
currPID = [SYSTEM_STATUS_TABLE+1];

[PROCESS_TABLE + currPID*16 + 4] = TERMINATED;

alias flag R1;
alias newPID R2;
newPID = 1;

while (newPID < 16) do

	if ([PROCESS_TABLE + newPID*16 + 4] != TERMINATED) then
		flag = 1;
		break;
	endif;
	newPID = (newPID+1);
endwhile;

if (flag == 1) then
	call SCHEDULER;
else
	halt;
endif;
