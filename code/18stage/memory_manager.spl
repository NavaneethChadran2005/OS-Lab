alias retVal R0;
alias funcNum R1;
alias arg1 R2;

if(funcNum == 1) then //get free page
    [SYSTEM_STATUS_TABLE + 3] = [SYSTEM_STATUS_TABLE + 3] + 1;
    while([SYSTEM_STATUS_TABLE + 2] == 0) do
        [PROCESS_TABLE + 16*[SYSTEM_STATUS_TABLE+1] + 4] = WAIT_MEM;
        multipush(R0, R1, R2);
        call SCHEDULER;
        multipop(R0, R1, R2);
    endwhile;

    [SYSTEM_STATUS_TABLE + 3] = [SYSTEM_STATUS_TABLE + 3] - 1; //waiting for mem count
    [SYSTEM_STATUS_TABLE + 2] = [SYSTEM_STATUS_TABLE + 2] - 1; //mem free count

    R3 = 0;
    while(R3 < MAX_MEM_PAGE) do
        if([MEMORY_FREE_LIST + R3] == 0) then
            retVal = R3; 
            [MEMORY_FREE_LIST + R3] = 1;
            break;
        endif;
        R3 = R3 + 1;
    endwhile;
    
    return;
endif;

if(funcNum == 2) then //release page
    [MEMORY_FREE_LIST + arg1] = [MEMORY_FREE_LIST + arg1] - 1;
    if([MEMORY_FREE_LIST + arg1] == 0) then
        [SYSTEM_STATUS_TABLE + 2] = [SYSTEM_STATUS_TABLE + 2] + 1;
        R3 = 1;
        while(R3 < 16) do
            if([PROCESS_TABLE + 16*R3 + 4] == WAIT_MEM) then
                [PROCESS_TABLE + 16*R3 + 4] = READY;
            endif;
            R3 = R3 + 1;
        endwhile;
    endif;

    return;
endif;